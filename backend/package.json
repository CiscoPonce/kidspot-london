{
  "name": "kidspot-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "KidSpot London Backend - API and data ingestion services",
  "main": "src/server.js",
  "author": "KidSpot London",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "kidspot",
    "london",
    "venues",
    "children",
    "parents",
    "api",
    "postgis",
    "geospatial"
  ],
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "download": "tsx scripts/download-datastore.js",
    "import": "tsx scripts/import-london-datastore.js",
    "verify": "tsx scripts/verify-import.js",
    "discover": "tsx scripts/discovery/run-discovery.ts",
    "discover:google": "tsx scripts/discovery/google-places-discovery.js",
    "discover:osm": "tsx scripts/discovery/osm-discovery.ts",
    "cron": "tsx scripts/cron-agent.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "typecheck": "tsc --noEmit",
    "perf:doctor": "clinic doctor -- tsx src/server.ts",
    "perf:flame": "clinic flame -- tsx src/server.ts",
    "perf:bubbleprof": "clinic bubbleprof -- tsx src/server.ts",
    "perf:heapprofiler": "clinic heapprofiler -- tsx src/server.ts"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bullmq": "^5.1.5",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^5.0.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "rate-limit-redis": "^4.2.0",
    "slugify": "^1.6.6",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autocannon": "^8.0.0",
    "clinic": "^13.0.0",
    "eslint": "^8.55.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  }
}
