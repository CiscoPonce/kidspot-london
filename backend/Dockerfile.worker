FROM node:20-slim

WORKDIR /app

COPY package*.json ./

RUN npm ci --only=production && \
    npm install -g pm2 && \
    npm cache clean --force

COPY . .

RUN groupadd -g 1001 nodejs && \
    useradd -r -u 1001 -g nodejs nodejs && \
    chown -R nodejs:nodejs /app

USER nodejs

CMD ["node", "src/worker.js"]
